{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"vite,laravel\" -c \"blue,green\" \"npm:dev:vite\" \"npm:dev:php\"",
    "dev:vite": "vite",
    "dev:php": "php artisan serve",
    "build": "vite build",
    "lint": "eslint resources/js --ext .js,.jsx --fix",
    "format": "prettier --write resources/js",
    "prepare": "husky"
  },
  "dependencies": {
    "@inertiajs/react": "^2.0.0",
    "aos": "^3.0.0-beta.6",
    "axios": "^1.7.4",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "laravel-vite-plugin": "^1.0.5",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2"
  },
  "lint-staged": {
    "**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.php": [
      "./vendor/bin/pint"
    ]
  }
}
